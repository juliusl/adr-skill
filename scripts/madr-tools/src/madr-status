#!/bin/bash
set -e

## usage: madr status [NUMBER] [STATUS]
##
## Without arguments, shows the status of all MADRs.
## With NUMBER, shows the status of that ADR.
## With NUMBER and STATUS, updates the status of that ADR.
##
## STATUS is one of: Proposed, Accepted, Deprecated, Superseded

if [ -f .madr-dir ]; then
    madr_dir=$(cat .madr-dir)
else
    madr_dir="docs/decisions"
fi

if [ ! -d "$madr_dir" ]; then
    echo "The $madr_dir directory does not exist" >&2
    exit 1
fi

if [ -z "$1" ]; then
    # Show all statuses
    for f in $(find "$madr_dir" -maxdepth 1 -name "[0-9]*.md" | sort); do
        name=$(basename "$f")
        status=$(grep -m1 "^## Status" -A2 "$f" | tail -1 | sed 's/^[[:space:]]*//')
        printf "%-50s %s\n" "$name" "$status"
    done
    exit 0
fi

number=$(printf "%04d" "$1")
target=$(find "$madr_dir" -maxdepth 1 -name "${number}*" | head -1)

if [ -z "$target" ] || [ ! -f "$target" ]; then
    echo "ERROR: ADR $1 not found" >&2
    exit 1
fi

if [ -z "$2" ]; then
    # Show single status
    grep -m1 "^## Status" -A2 "$target" | tail -1
else
    # Update status
    new_status="$2"
    # Replace the line after "## Status" (skip blank lines)
    sed -i "/^## Status/{n;/^$/n;s/.*/$new_status/}" "$target"
    echo "Updated $(basename "$target") → $new_status"
fi
