#!/bin/bash
# Config for madr-tools. Sources from the skill's template directory.
basedir=$(cd -L $(dirname $0) >/dev/null 2>&1 && pwd -L)
skill_root=$(cd -L "$basedir/../../.." >/dev/null 2>&1 && pwd -L)

echo 'madr_bin_dir="'"${basedir}"'"'
echo 'madr_template_dir="'"${skill_root}/assets/templates"'"'
