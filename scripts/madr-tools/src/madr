#!/bin/bash
set -e

## usage: madr COMMAND [ARG] ...
##
## Manage MADR (Markdown Architectural Decision Records).
##
## Commands:
##   init       Initialize a new MADR directory
##   new        Create a new MADR
##   list       List all MADRs
##   status     Show or update ADR status
##   generate   Generate table of contents
##   help       Show help

bindir=$(cd -L $(dirname $0) >/dev/null 2>&1 && pwd -L)
cmd="${1:?COMMAND required. Run 'madr help' for usage.}"
shift
"$bindir/madr-$cmd" "$@"
