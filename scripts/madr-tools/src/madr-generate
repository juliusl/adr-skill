#!/bin/bash
set -e

## usage: madr generate toc [-p PREFIX]
##
## Generates a table of contents from all MADRs.
##
## Options:
##   -p PREFIX   Path prefix for links (default: empty)

prefix=""
while getopts "p:" opt; do
    case $opt in
        p) prefix="$OPTARG";;
    esac
done

if [ -f .madr-dir ]; then
    madr_dir=$(cat .madr-dir)
else
    madr_dir="docs/decisions"
fi

if [ ! -d "$madr_dir" ]; then
    echo "The $madr_dir directory does not exist" >&2
    exit 1
fi

echo "# Architecture Decision Log"
echo ""

for f in $(find "$madr_dir" -maxdepth 1 -name "[0-9]*.md" | sort); do
    name=$(basename "$f")
    title=$(head -1 "$f" | sed 's/^#\s*//')
    status=$(grep -m1 "^## Status" -A2 "$f" | tail -1 | sed 's/^[[:space:]]*//')
    echo "- [$title](${prefix}${name}) — *${status}*"
done
