#!/bin/bash
set -e

## usage: madr list
##
## Lists the MADR decision records in the current project.

if [ -f .madr-dir ]; then
    madr_dir=$(cat .madr-dir)
else
    madr_dir="docs/decisions"
fi

if [ -d "$madr_dir" ]; then
    find "$madr_dir" -maxdepth 1 -name "[0-9]*.md" | sort
else
    echo "The $madr_dir directory does not exist" >&2
    exit 1
fi
